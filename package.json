{
  "name": "@alanizcreative/formation-static",
  "version": "0.0.4",
  "description": "Minimal static-site HTML renderer from JSON, Contentful, or WordPress data",
  "main": "./lib/config/config.js",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "files": [
    "./lib",
    "./cjs"
  ],
  "exports": {
    "./*": {
      "import": "./lib/*",
      "require": "./cjs/*"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:lib": "npx tsc --project tsconfig.lib.json",
    "build:cjs": "npx tsc --project tsconfig.cjs.json",
    "build": "pnpm build:lib && pnpm build:cjs && node scripts/packageFile.js && pnpm minify",
    "minify": "find lib cjs -name \"*.js\" -exec terser {} -o {} --compress \\;",
    "test": "vitest --run --reporter verbose --coverage",
    "lint": "npx eslint ."
  },
  "keywords": [
    "static-site",
    "renderer",
    "html",
    "nodejs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/galaniz/formation-static.git"
  },
  "bugs": {
    "url": "https://github.com/galaniz/formation-static/issues"
  },
  "homepage": "https://github.com/galaniz/formation-static#readme",
  "author": "Graciela Alaniz (https://alanizcreative.com/)",
  "license": "MIT",
  "devDependencies": {
    "@types/contentful-resolve-response": "^0.1.33",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "10.1.0",
    "memfs": "4.57.1",
    "terser": "5.46.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "8.58.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "@wordpress/block-serialization-default-parser": "^5.37.0",
    "contentful-resolve-response": "^1.9.4",
    "sharp": "0.34.5"
  },
  "peerDependenciesMeta": {
    "@wordpress/block-serialization-default-parser": {
      "optional": true
    },
    "contentful-resolve-response": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  },
  "release-it": {
    "git": {
      "requireCommits": true,
      "commitMessage": "chore: release ${version} [ci skip]",
      "tag": true,
      "push": true
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": true,
      "skipChecks": true
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
